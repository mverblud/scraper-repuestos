{
  "info": {
    "name": "Scraper Repuestos API",
    "description": "API REST para scraping de catálogos de proveedores de repuestos automotor.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verifica que el servidor esté corriendo."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"ok\",\n  \"timestamp\": \"2024-01-01T00:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Scraper",
      "item": [
        {
          "name": "Buscar productos",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/scraper/productos",
              "host": ["{{baseUrl}}"],
              "path": ["scraper", "productos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoAuto\": \"\",\n  \"marcaId\": \"\",\n  \"rubroId\": \"\",\n  \"cantidadRenglones\": 50\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Busca productos en el catálogo del proveedor Ramos.\n\n**Campos del body:**\n- `codigoAuto` (string): Código del vehículo (max 200 chars)\n- `marcaId` (string): ID de la marca (max 10 chars)\n- `rubroId` (string): ID del rubro (max 10 chars)\n- `cantidadRenglones` (integer, 1-500): Cantidad máxima de resultados"
          },
          "response": [
            {
              "name": "200 - Búsqueda exitosa",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"params\": {\n    \"codigoAuto\": \"\",\n    \"marcaId\": \"\",\n    \"rubroId\": \"\",\n    \"cantidadRenglones\": 50\n  },\n  \"totalProductos\": 1,\n  \"productos\": [\n    {\n      \"codigo\": \"ABC123\",\n      \"marca\": \"Toyota\",\n      \"rubro\": \"Filtros\",\n      \"nombre\": \"Filtro de aceite\",\n      \"porcentajeIVA\": 21,\n      \"precio\": 1500.00,\n      \"foto\": null,\n      \"descuento\": 55,\n      \"costo\": 675.00,\n      \"precioSugerido\": 1800.00\n    }\n  ]\n}"
            },
            {
              "name": "400 - Parámetros inválidos",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Parámetros inválidos\",\n  \"details\": {}\n}"
            },
            {
              "name": "401 - Error de autenticación",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Error de autenticación\",\n  \"message\": \"No se pudo iniciar sesión con el proveedor\"\n}"
            },
            {
              "name": "502 - Error del proveedor",
              "status": "Bad Gateway",
              "code": 502,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Error del proveedor\",\n  \"message\": \"El proveedor no respondió correctamente\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Marcas",
      "item": [
        {
          "name": "Listar todas las marcas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/marcas",
              "host": ["{{baseUrl}}"],
              "path": ["marcas"]
            },
            "description": "Retorna el listado completo de marcas."
          },
          "response": [
            {
              "name": "200 - Lista de marcas",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  { \"marcaId\": 1, \"marcaName\": \"TOYOTA\", \"marcaHabilitado\": true },\n  { \"marcaId\": 2, \"marcaName\": \"FORD\",   \"marcaHabilitado\": false }\n]"
            }
          ]
        },
        {
          "name": "Obtener marca por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/marcas/1",
              "host": ["{{baseUrl}}"],
              "path": ["marcas", "1"]
            },
            "description": "Retorna una marca específica por su ID."
          },
          "response": [
            {
              "name": "200 - Marca encontrada",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"marcaId\": 1, \"marcaName\": \"TOYOTA\", \"marcaHabilitado\": true }"
            },
            {
              "name": "404 - No encontrada",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"No encontrado\",\n  \"message\": \"Marca con id 1 no encontrada\"\n}"
            }
          ]
        },
        {
          "name": "Crear marca",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/marcas",
              "host": ["{{baseUrl}}"],
              "path": ["marcas"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"marcaName\": \"HONDA\",\n  \"marcaHabilitado\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crea una nueva marca.\n\n**Campos:**\n- `marcaName` (string, requerido): Nombre de la marca (max 100 chars)\n- `marcaHabilitado` (boolean, opcional): Default `true`"
          },
          "response": [
            {
              "name": "201 - Marca creada",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"marcaId\": 66, \"marcaName\": \"HONDA\", \"marcaHabilitado\": true }"
            },
            {
              "name": "400 - Parámetros inválidos",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Parámetros inválidos\",\n  \"details\": { \"marcaName\": [\"marcaName es requerido\"] }\n}"
            },
            {
              "name": "409 - Conflicto",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Conflicto\",\n  \"message\": \"Ya existe una marca con el nombre \\\"HONDA\\\"\"\n}"
            }
          ]
        },
        {
          "name": "Actualizar marca",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/marcas/1",
              "host": ["{{baseUrl}}"],
              "path": ["marcas", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"marcaName\": \"TOYOTA ACTUALIZADO\",\n  \"marcaHabilitado\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Actualiza parcialmente una marca. Todos los campos son opcionales."
          },
          "response": [
            {
              "name": "200 - Marca actualizada",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"marcaId\": 1, \"marcaName\": \"TOYOTA ACTUALIZADO\", \"marcaHabilitado\": false }"
            },
            {
              "name": "404 - No encontrada",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"No encontrado\",\n  \"message\": \"Marca con id 1 no encontrada\"\n}"
            },
            {
              "name": "409 - Conflicto",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Conflicto\",\n  \"message\": \"Ya existe una marca con el nombre \\\"TOYOTA ACTUALIZADO\\\"\"\n}"
            }
          ]
        },
        {
          "name": "Eliminar marca",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/marcas/1",
              "host": ["{{baseUrl}}"],
              "path": ["marcas", "1"]
            },
            "description": "Elimina una marca por su ID."
          },
          "response": [
            {
              "name": "204 - Eliminada",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "404 - No encontrada",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"No encontrado\",\n  \"message\": \"Marca con id 1 no encontrada\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
