## Testing

### Unit Test del ErrorHandler

```typescript
import { ErrorHandler } from '../middleware/errorHandler';
import { NotFoundError, ConflictError, LoginError } from '../../domain/errors';

describe('ErrorHandler', () => {
  let mockReply: any;
  let mockLog: any;

  beforeEach(() => {
    mockReply = {
      status: jest.fn().mockReturnThis(),
      send: jest.fn().mockReturnThis(),
    };
    mockLog = {
      warn: jest.fn(),
      error: jest.fn(),
      info: jest.fn(),
    };
  });

  describe('NotFoundError → 404', () => {
    it('debe retornar 404 con mensaje correcto', () => {
      const error = new NotFoundError('Marca no encontrada');

      ErrorHandler.handle(error, mockReply, mockLog);

      expect(mockReply.status).toHaveBeenCalledWith(404);
      expect(mockReply.send).toHaveBeenCalledWith({
        error: 'No encontrado',
        message: 'Marca no encontrada',
      });
    });
  });

  describe('ConflictError → 409', () => {
    it('debe retornar 409 para conflictos', () => {
      const error = new ConflictError('Nombre ya existe');

      ErrorHandler.handle(error, mockReply, mockLog);

      expect(mockReply.status).toHaveBeenCalledWith(409);
      expect(mockReply.send).toHaveBeenCalledWith({
        error: 'Conflicto',
        message: 'Nombre ya existe',
      });
    });
  });

  describe('LoginError → 401', () => {
    it('debe loguear warning y retornar 401', () => {
      const error = new LoginError('Credenciales inválidas');

      ErrorHandler.handle(error, mockReply, mockLog);

      expect(mockLog.warn).toHaveBeenCalled();
      expect(mockReply.status).toHaveBeenCalledWith(401);
    });
  });

  describe('Error desconocido → 500', () => {
    it('debe retornar 500 para errores genéricos', () => {
      const error = new Error('Algo salió mal');

      ErrorHandler.handle(error, mockReply, mockLog);

      expect(mockLog.error).toHaveBeenCalled();
      expect(mockReply.status).toHaveBeenCalledWith(500);
      expect(mockReply.send).toHaveBeenCalledWith({
        error: 'Error interno del servidor',
        message: 'Ocurrió un error inesperado',
      });
    });
  });
});
```

### Integration Test de Endpoint

```typescript
import { build } from '../app'; // tu setup de Fastify

describe('Endpoint con ErrorHandler', () => {
  let app: any;

  beforeAll(async () => {
    app = await build();
  });

  afterAll(async () => {
    await app.close();
  });

  it('GET /marcas/:id retorna 404 si no existe', async () => {
    const response = await app.inject({
      method: 'GET',
      url: '/marcas/9999',
    });

    expect(response.statusCode).toBe(404);
    expect(JSON.parse(response.body)).toEqual({
      error: 'No encontrado',
      message: expect.any(String),
    });
  });

  it('POST /marcas retorna 409 si ya existe', async () => {
    // Primero crear una marca
    await app.inject({
      method: 'POST',
      url: '/marcas',
      payload: { marcaName: 'TOYOTA' },
    });

    // Intentar crear la misma
    const response = await app.inject({
      method: 'POST',
      url: '/marcas',
      payload: { marcaName: 'TOYOTA' },
    });

    expect(response.statusCode).toBe(409);
    expect(JSON.parse(response.body).error).toBe('Conflicto');
  });
});
```

---

## Checklist de Implementación

- [ ] Crear `src/interface/middleware/errorHandler.ts`
- [ ] Importar todos los errores de dominio
- [ ] Mapear cada error a código HTTP + formato de respuesta
- [ ] Loguear errores críticos (401, 502, 500)
- [ ] Exportar en `src/interface/middleware/index.ts`
- [ ] Usar `ErrorHandler.handle()` en todas las rutas
- [ ] Remover funciones `handleError()` locales
- [ ] Escribir unit tests
- [ ] Verificar integration tests
- [ ] Documentar en README

---

## Tablas de Referencia

### Mapeo de Errores → HTTP

| Error | HTTP | Razón |
|-------|------|-------|
| `InvalidParamsError` | 400 | Validación falló |
| `LoginError` | 401 | No autenticado |
| `NotFoundError` | 404 | Recurso no existe |
| `ConflictError` | 409 | Conflicto (ej: duplicado) |
| `ProviderError` | 502 | Proveedor down |
| `ParsingError` | 502 | Respuesta inesperada |
| Genérico `Error` | 500 | Error no controlado |

### Logging Recomendado

| Tipo | Método | Ejemplo |
|------|--------|---------|
| Éxito | `info` | `request.log.info({ marca }, 'Marca creada')` |
| Advertencia | `warn` | `request.log.warn({ attempts: 3 }, 'Login repetido')` |
| Error | `error` | `request.log.error({ err }, 'Provider falla')` |

