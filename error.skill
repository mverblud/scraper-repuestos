## Extender para Nuevos Errores

### Paso 1: Crear Error de Dominio

**Archivo:** `src/domain/errors/ProductNotAvailableError.ts`

```typescript
export class ProductNotAvailableError extends Error {
  constructor(codigo: string) {
    super(`Producto ${codigo} no disponible en stock`);
    this.name = 'ProductNotAvailableError';
  }
}
```

### Paso 2: Exportar en Index

**Archivo:** `src/domain/errors/index.ts`

```typescript
export { LoginError } from './LoginError';
export { NotFoundError } from './NotFoundError';
export { ProductNotAvailableError } from './ProductNotAvailableError';
// ... más
```

### Paso 3: Agregar en ErrorHandler

**Archivo:** `src/interface/middleware/errorHandler.ts`

```typescript
import { ProductNotAvailableError } from '../../domain/errors';

export class ErrorHandler {
  static handle(
    error: unknown,
    reply: FastifyReply,
    log: FastifyRequest['log'],
  ): FastifyReply {
    // ... errores anteriores ...

    // ✅ NUEVO: Mapear ProductNotAvailableError
    if (error instanceof ProductNotAvailableError) {
      return reply.status(404).send({
        error: 'Producto no disponible',
        message: error.message,
      });
    }

    // ... resto del código ...
  }
}
```

