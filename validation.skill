## Testing

### Unit Test de Schema Zod

```typescript
import { CreateMarcaSchema } from '../schemas';

describe('CreateMarcaSchema', () => {
  describe('Validación exitosa', () => {
    it('debe aceptar datos válidos', () => {
      const data = { marcaName: 'TOYOTA', marcaHabilitado: true };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(true);
      if (result.success) {
        expect(result.data.marcaName).toBe('TOYOTA');
        expect(result.data.marcaHabilitado).toBe(true);
      }
    });

    it('debe aplicar defaults', () => {
      const data = { marcaName: 'FORD' };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(true);
      if (result.success) {
        expect(result.data.marcaHabilitado).toBe(true); // default
      }
    });

    it('debe trimear strings', () => {
      const data = { marcaName: '  HONDA  ' };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(true);
      if (result.success) {
        expect(result.data.marcaName).toBe('HONDA');
      }
    });
  });

  describe('Validación fallida', () => {
    it('rechaza nombre vacío', () => {
      const data = { marcaName: '' };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(false);
      if (!result.success) {
        expect(result.error.flatten().fieldErrors.marcaName).toBeDefined();
      }
    });

    it('rechaza nombre > 100 caracteres', () => {
      const data = { marcaName: 'A'.repeat(101) };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(false);
    });

    it('rechaza estado no-booleano', () => {
      const data = { marcaName: 'TOYOTA', marcaHabilitado: 'yes' };
      const result = CreateMarcaSchema.safeParse(data);

      expect(result.success).toBe(false);
    });
  });
});
```

### Integration Test de Endpoint

```typescript
import { build } from '../app'; // Fastify setup

describe('POST /marcas', () => {
  let app: any;

  beforeAll(async () => {
    app = await build();
  });

  afterAll(async () => {
    await app.close();
  });

  it('retorna 400 si marcaName está vacío', async () => {
    const response = await app.inject({
      method: 'POST',
      url: '/marcas',
      payload: { marcaName: '' },
    });

    expect(response.statusCode).toBe(400);
    const body = JSON.parse(response.body);
    expect(body.error).toBe('Parámetros inválidos');
  });

  it('retorna 201 con marca creada', async () => {
    const response = await app.inject({
      method: 'POST',
      url: '/marcas',
      payload: { marcaName: 'SUBARU' },
    });

    expect(response.statusCode).toBe(201);
    const marca = JSON.parse(response.body);
    expect(marca).toHaveProperty('marcaId');
    expect(marca.marcaName).toBe('SUBARU');
    expect(marca.marcaHabilitado).toBe(true);
  });
});
```

