# Variables de entorno - Scraper Repuestos
# Copiar a .env y completar con valores reales

# URLs del proveedor Ramos
LOGIN_URL=https://gesis2.com/autopartesramos/src/ctrl/login.ctrl.php
CATALOG_URL=https://gesis2.com/autopartesramos/src/ctrl/consultar_articulos.ctrl.php
SEARCH_URL=https://gesis2.com/autopartesramos/src/ctrl/ajax/obtener_articulos.ajax.php

# Credenciales del proveedor Ramos (NUNCA commitear .env)
PROVIDER_USER=
PROVIDER_PASSWORD=

# ID del cliente en el sistema del proveedor (fallback si no se puede extraer dinámicamente)
PROVIDER_CLIENT_ID=308

# ─── ASM (Autopartes San Martín) ─────────────────────────────────────────
# URL base del sitio ASM (WordPress/WooCommerce)
ASM_BASE_URL=https://autopartessanmartin.com.ar

# Credenciales de acceso a ASM (NUNCA commitear .env)
ASM_USER=
ASM_PASSWORD=

# Servidor
PORT=3000
HOST=0.0.0.0
