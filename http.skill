## Mejoras Futuras

### 1. Validador Helper

```typescript
// src/interface/utils/validation.ts
export async function validateBody<T>(
  schema: z.Schema<T>,
  body: unknown,
  reply: FastifyReply,
): Promise<T | null> {
  const parsed = schema.safeParse(body);
  if (!parsed.success) {
    reply.status(400).send({
      error: 'Parámetros inválidos',
      details: parsed.error.flatten().fieldErrors,
    });
    return null;
  }
  return parsed.data;
}

// Usar en routes
const dto = await validateBody(CreateMarcaSchema, request.body, reply);
if (!dto) return;
```

### 2. Controller Class (si crece)

```typescript
export class MarcasController {
  constructor(private readonly service: MarcasService) {}

  async getAll(request: FastifyRequest, reply: FastifyReply) {
    try {
      const marcas = await this.service.getAll();
      return reply.send(marcas);
    } catch (error) {
      return ErrorHandler.handle(error, reply, request.log);
    }
  }

  async getById(request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) {
    // ... similar
  }
}
```

### 3. Middleware Custom

```typescript
// src/interface/middleware/authMiddleware.ts
export async function authMiddleware(request: FastifyRequest, reply: FastifyReply) {
  const token = request.headers.authorization?.replace('Bearer ', '');
  if (!token) {
    return reply.status(401).send({ error: 'No authorized' });
  }
  // Validar token
  request.user = decodeToken(token);
}

// Usar en routes
fastify.get('/marked-secure', {
  onRequest: [authMiddleware],
}, async (request, reply) => {
  // Solo alcanzable si token válido
});
```

